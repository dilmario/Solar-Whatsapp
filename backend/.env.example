# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=saas-solar-bot
APP_ENV=dev
APP_DEBUG=false

# ── Evolution API ──────────────────────────────────────────────────────────────
EVOLUTION_BASE_URL=http://evolution-api:8080
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE=saas-bot
EVOLUTION_WEBHOOK_SECRET=troque-por-um-segredo-forte

# ── Gemini ─────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=sua-chave-gemini-aqui
MODEL_NAME=gemini-2.0-flash
TEMPERATURE=0.4

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ───────────────────────────────────────────────────────────────────────
# Em produção, use o domínio real do frontend. Separe múltiplos por vírgula.
CORS_ORIGINS=http://localhost:3000

# ── Follow-up ──────────────────────────────────────────────────────────────────
# Intervalo de varredura do worker (segundos). Default: 300 = 5 minutos
FOLLOWUP_INTERVALO_SEGUNDOS=300
# Janelas de inatividade para cada disparo
FOLLOWUP_JANELA_2H=7200
FOLLOWUP_JANELA_24H=86400
FOLLOWUP_JANELA_3D=259200
# Máximo de tentativas antes de marcar o lead como perdido
FOLLOWUP_MAX_TENTATIVAS=3
