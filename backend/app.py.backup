from flask import Flask, request, jsonify
import os
import requests

app = Flask(__name__)

# Configurações
WHATSAPP_API_URL = "https://graph.facebook.com/v17.0"
PHONE_NUMBER_ID = os.getenv("WHATSAPP_PHONE_NUMBER_ID")
ACCESS_TOKEN = os.getenv("WHATSAPP_ACCESS_TOKEN")

@app.route('/')
def home():
    return jsonify({"status": "API do Consultor Solar Online", "version": "1.0.0"})

@app.route('/webhook', methods=['GET', 'POST'])
def webhook():
    """Webhook para receber mensagens do WhatsApp"""
    if request.method == 'GET':
        # Verificação do webhook (Facebook requer isso)
        mode = request.args.get('hub.mode')
        token = request.args.get('hub.verify_token')
        challenge = request.args.get('hub.challenge')
        
        verify_token = os.getenv('WEBHOOK_VERIFY_TOKEN', 'meu_token_secreto')
        
        if mode == 'subscribe' and token == verify_token:
            return challenge, 200
        return 'Verification failed', 403
    
    # POST - Receber mensagens
    data = request.json
    print(f"Mensagem recebida: {data}")
    
    # Aqui você processaria a mensagem e responderia
    # Por enquanto, apenas confirma recebimento
    return jsonify({"status": "received"}), 200

@app.route('/send-message', methods=['POST'])
def send_message():
    """Enviar mensagem via WhatsApp API"""
    try:
        data = request.json
        phone = data.get('phone')
        message = data.get('message')
        
        if not phone or not message:
            return jsonify({"error": "Phone and message required"}), 400
        
        # URL da API do WhatsApp
        url = f"{WHATSAPP_API_URL}/{PHONE_NUMBER_ID}/messages"
        
        headers = {
            "Authorization": f"Bearer {ACCESS_TOKEN}",
            "Content-Type": "application/json"
        }
        
        payload = {
            "messaging_product": "whatsapp",
            "to": phone,
            "type": "text",
            "text": {"body": message}
        }
        
        # Enviar mensagem (comentado por enquanto - precisa de tokens reais)
        # response = requests.post(url, json=payload, headers=headers)
        # return jsonify(response.json()), response.status_code
        
        # Simulação para desenvolvimento
        return jsonify({
            "status": "success",
            "message": f"Mensagem simulada enviada para {phone}",
            "content": message
        }), 200
        
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route('/consultor/qualificar', methods=['POST'])
def qualificar_lead():
    """Endpoint para qualificação automática de lead"""
    data = request.json
    
    # Simulação de lógica de qualificação
    conta_luz = data.get('conta_luz', 0)
    tipo_rede = data.get('tipo_rede', 'monofásica')
    cidade = data.get('cidade', '')
    
    # Lógica simples de qualificação
    if conta_luz > 300:
        classificacao = "QUENTE"
        economia_estimada = conta_luz * 0.9
    elif conta_luz > 150:
        classificacao = "MORNO"
        economia_estimada = conta_luz * 0.85
    else:
        classificacao = "FRIO"
        economia_estimada = conta_luz * 0.8
    
    return jsonify({
        "classificacao": classificacao,
        "economia_estimada_mensal": round(economia_estimada, 2),
        "investimento_estimado": round(economia_estimada * 12 * 5, 2),  # 5 anos de retorno
        "proximo_passo": "Agendar visita técnica" if classificacao == "QUENTE" else "Enviar proposta detalhada"
    })
def enviar_resposta_evolution(destinatario, texto):
    """Envia uma mensagem de volta via Evolution API"""
    try:
        import requests
        
        # Extrair o número (remover sufixo @s.whatsapp.net se existir)
        numero = destinatario.split('@')[0]
        
        # URL da Evolution API (use o nome da sua instância)
        url = "http://evolution-api:8081/message/sendText/consultor-solar"
        
        payload = {
            "number": numero,
            "text": texto,
            "delay": 1000  # delay de 1 segundo (opcional)
        }
        
        headers = {
            "Content-Type": "application/json"
        }
        
        print(f"📤 Enviando resposta para {numero}: {texto[:50]}...")
        
        response = requests.post(url, json=payload, headers=headers)
        
        if response.status_code == 201:
            print(f"✅ Resposta enviada com sucesso")
        else:
            print(f"❌ Erro ao enviar resposta: {response.text}")
            
    except Exception as e:
        print(f"❌ Erro na função enviar_resposta_evolution: {e}")

if __name__ == '__main__':
    app.run(debug=True, host='0.0.0.0')

@app.route('/evolution-webhook', methods=['GET', 'POST'])
def evolution_webhook():
    """Endpoint para receber webhooks da Evolution API"""
    
    # VERIFICAÇÃO (GET) - chamado pela Evolution ao configurar
    if request.method == 'GET':
        token = request.args.get('token')
        if token == 'meu_token_secreto_evolution':
            return {"status": "verified"}, 200
        else:
            return {"error": "Invalid token"}, 403
    
    # RECEBER MENSAGENS (POST)
	if request.method == 'POST':
    	data = request.json
    	print(f"📩 Webhook recebido: {json.dumps(data, indent=2)}")
    
    	try:
        # Extrair informações da mensagem (formato Baileys/Evolution)
        evento = data.get('event')
        
        # Só processar se for mensagem nova
        if evento == 'messages.upsert':
            mensagem_data = data.get('data', {})
            mensagem = mensagem_data.get('message', {})
            
            # Número do remetente
            from_number = mensagem.get('key', {}).get('remoteJid', '')
            
            # Extrair texto da mensagem
            texto = ''
            if 'conversation' in mensagem:
                texto = mensagem['conversation']
            elif 'extendedTextMessage' in mensagem:
                texto = mensagem['extendedTextMessage'].get('text', '')
            
            # Ignorar mensagens do próprio sistema
            if 'status' in from_number or from_number.endswith('@g.us'):
                return {"status": "ignored"}, 200
            
            print(f"💬 Mensagem de {from_number}: {texto}")
            
            # SE A MENSAGEM NÃO FOR VAZIA, RESPONDE
            if texto.strip():
                resposta = f"Recebi sua mensagem: '{texto}'. Em breve um consultor responderá!"
                enviar_resposta_evolution(from_number, resposta)
        
        return {"status": "processed"}, 200
        
    except Exception as e:
        print(f"❌ Erro ao processar webhook: {e}")
        return {"error": str(e)}, 500
