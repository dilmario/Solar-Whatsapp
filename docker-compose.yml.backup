version: '3.8'

services:
  web:
    image: node:18-alpine
    container_name: solar-frontend
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=development
      - NEXT_PUBLIC_API_URL=http://backend:5000
    volumes:
      - .:/app
      - /app/node_modules
    working_dir: /app
    command: sh -c "npm install && npm run dev"
    depends_on:
      - backend
    networks:
      - solar-network

  backend:
    build: ./backend
    container_name: solar-backend
    ports:
      - "5000:5000"
    environment:
      - FLASK_ENV=development
      - WHATSAPP_API_TOKEN=${WHATSAPP_API_TOKEN}
    volumes:
      - ./backend:/app
    networks:
      - solar-network

networks:
  solar-network:
    driver: bridge
