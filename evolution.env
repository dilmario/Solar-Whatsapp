# ==============================
# AUTH (obrigatório)
# ==============================
AUTHENTICATION_API_KEY=429683C4C977415CAAFCCE10F7D57E11

# ==============================
# BANCO DE DADOS (Postgres)
# ==============================
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@postgres:5432/evolution

# (opcional) separa múltiplas instalações no mesmo DB
# DATABASE_CONNECTION_CLIENT_NAME=solar_whatsapp

# ==============================
# REDIS / CACHE (v2)
# ==============================
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6

# ==============================
# CONEXÃO WHATSAPP (Baileys)
# ==============================
CONNECTION_TYPE=baileys

# Nome “default” sugerido (algumas telas usam o nome da instância criado via API/painel)
INSTANCE_NAME=Consultor_Solar
ENABLED=true

# Versão do “client” usada na sessão (muito importante no Baileys)
# Se QR gerar mas não conectar, este é o 1º ajuste a tentar.
CONFIG_SESSION_PHONE_VERSION=2.2432.5.0

# Quantidade de QR gerados antes de bloquear/limitar
QRCODE_LIMIT=30

# ==============================
# WEBHOOK (Evolution -> seu backend Flask)
# ==============================
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://backend:5000/evolution-webhook

# Eventos comuns (ative conforme sua necessidade)
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_QRCODE_UPDATED=true

# ==============================
