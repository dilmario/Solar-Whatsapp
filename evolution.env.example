# =CONFIGURE_AQUI
# AUTH (obrigatório)
# =CONFIGURE_AQUI
AUTHENTICATION_API_KEY=CONFIGURE_AQUI

# =CONFIGURE_AQUI
# BANCO DE DADOS (Postgres)
# =CONFIGURE_AQUI
DATABASE_ENABLED=CONFIGURE_AQUI
DATABASE_PROVIDER=CONFIGURE_AQUI
DATABASE_CONNECTION_URI=CONFIGURE_AQUI

# (opcional) separa múltiplas instalações no mesmo DB
# DATABASE_CONNECTION_CLIENT_NAME=CONFIGURE_AQUI

# =CONFIGURE_AQUI
# REDIS / CACHE (v2)
# =CONFIGURE_AQUI
CACHE_REDIS_ENABLED=CONFIGURE_AQUI
CACHE_REDIS_URI=CONFIGURE_AQUI

# =CONFIGURE_AQUI
# CONEXÃO WHATSAPP (Baileys)
# =CONFIGURE_AQUI
CONNECTION_TYPE=CONFIGURE_AQUI

# Nome “default” sugerido (algumas telas usam o nome da instância criado via API/painel)
INSTANCE_NAME=CONFIGURE_AQUI
ENABLED=CONFIGURE_AQUI

# Versão do “client” usada na sessão (muito importante no Baileys)
# Se QR gerar mas não conectar, este é o 1º ajuste a tentar.
CONFIG_SESSION_PHONE_VERSION=CONFIGURE_AQUI

# Quantidade de QR gerados antes de bloquear/limitar
QRCODE_LIMIT=CONFIGURE_AQUI

# =CONFIGURE_AQUI
# WEBHOOK (Evolution -> seu backend Flask)
# =CONFIGURE_AQUI
WEBHOOK_GLOBAL_ENABLED=CONFIGURE_AQUI
WEBHOOK_GLOBAL_URL=CONFIGURE_AQUI

# Eventos comuns (ative conforme sua necessidade)
WEBHOOK_EVENTS_MESSAGES_UPSERT=CONFIGURE_AQUI
WEBHOOK_EVENTS_CONNECTION_UPDATE=CONFIGURE_AQUI
WEBHOOK_EVENTS_QRCODE_UPDATED=CONFIGURE_AQUI

# =CONFIGURE_AQUI
# CALENDLY (integração com a agenda)
# =CONFIGURE_AQUI
CALENDLY_API_KEY=CONFIGURE_AQUI
CALENDLY_EVENT_ID=CONFIGURE_AQUI

# =CONFIGURE_AQUI
# LOGS
# =CONFIGURE_AQUI
LOG_LEVEL=CONFIGURE_AQUI
